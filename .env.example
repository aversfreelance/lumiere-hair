# Neon PostgreSQL connection string
# Get yours at https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT secret for admin authentication (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Vercel Blob — required for photo uploads in production (https://vercel.com/docs/storage/vercel-blob)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
